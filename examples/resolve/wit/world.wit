package example:resolve;

world resolve {
    // output-stream + blocking-write-and-flush: the actual stdout write.
    import wasi:io/streams@0.2.6;
    // pollable.block: wait until the resolver has more addresses.
    import wasi:io/poll@0.2.6;
    // get-stdout: yields the output-stream output is written to.
    import wasi:cli/stdout@0.2.6;
    // exit-with-code: reports the u8 process exit code to the host.
    import wasi:cli/exit@0.2.6;
    // instance-network: the network handle resolution runs against.
    import wasi:sockets/instance-network@0.2.6;
    // resolve-addresses + resolve-address-stream: hostname -> IPs.
    import wasi:sockets/ip-name-lookup@0.2.6;
    // run: the command entry point.
    export wasi:cli/run@0.2.6;
}
