.{
    .version = 1,
    .runtime = "wasmtime",
    .runtimeArgs = .{
        "serve",
        "-W", "component-model-async",
        "-W", "component-model-async-stackful",
        "-W", "component-model-more-async-builtins",
        "-W", "component-model-error-context",
        "-S", "cli-exit-with-code",
    },
}
