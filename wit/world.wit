package example:petstore;

/// A data storage service.
interface store {
    record pet {
        id: u32,
        name: string,
        tag: option<string>,
        age: u32,
    }

    record toy {
        id: u32,
        pet-id: u32,
        name: string,
    }

    /// Number of pets currently stored.
    pet-count: func() -> u32;
    /// The pet at a 0-based dense index `0..pet-count`, or none.
    pet-at: func(index: u32) -> option<pet>;
    /// The pet with the given id, or none.
    get-pet: func(id: u32) -> option<pet>;
    /// Create a pet; none when the store is full.
    create-pet: func(name: string, tag: option<string>, age: u32) -> option<pet>;
    /// Delete a pet; true when it existed.
    delete-pet: func(id: u32) -> bool;
    /// Number of toys belonging to a pet.
    toy-count: func(pet-id: u32) -> u32;
    /// The `index`-th toy of a pet, or none.
    toy-at: func(pet-id: u32, index: u32) -> option<toy>;
}

// The web service.
world web {
    import wasi:http/types@0.3.0;
    import store;
    export wasi:http/handler@0.3.0;
}

// The storage component: exports the `store` interface.
world store-provider {
    export store;
}
