package example:petstore;

// A web component.
world web {
    import wasi:http/types@0.3.0;
    import store;
    export wasi:http/handler@0.3.0;
}

// A storage component.
world storage {
    export store;
}

// A demo CLI client that walks every petstore endpoint in order. It makes
// outgoing requests through the imported `wasi:http/client` (the host's
// outgoing HTTP client) and prints a transcript to stdout.
world client {
    import wasi:http/types@0.3.0;
    import wasi:http/client@0.3.0;
    import wasi:cli/stdout@0.3.0;
    import wasi:cli/stderr@0.3.0;
    import wasi:cli/environment@0.3.0;
    import wasi:cli/exit@0.3.0;
    export wasi:cli/run@0.3.0;
}

/// A data storage interface.
interface store {
    record pet {
        id: u32,
        name: string,
        tag: option<string>,
        age: u32,
    }

    record toy {
        id: u32,
        pet-id: u32,
        name: string,
    }

    /// Number of pets currently stored.
    pet-count: func() -> u32;
    /// The pet at a 0-based dense index `0..pet-count`, or none.
    pet-at: func(index: u32) -> option<pet>;
    /// The pet with the given id, or none.
    get-pet: func(id: u32) -> option<pet>;
    /// Create a pet; none when the store is full.
    create-pet: func(name: string, tag: option<string>, age: u32) -> option<pet>;
    /// Delete a pet; true when it existed.
    delete-pet: func(id: u32) -> bool;
    /// Number of toys belonging to a pet.
    toy-count: func(pet-id: u32) -> u32;
    /// The `index`-th toy of a pet, or none.
    toy-at: func(pet-id: u32, index: u32) -> option<toy>;
}
